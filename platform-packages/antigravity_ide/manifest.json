{
  "id": "antigravity_ide",
  "platformId": "antigravity_ide",
  "version": "1.0.1",
  "apiVersion": 1,
  "minCoreVersion": "1.0.0",
  "displayName": "Antigravity IDE",
  "entry": "runtime/index.json",
  "packageMode": "hotUpdate",
  "installKind": "sidecarAdapter",
  "adapter": {
    "protocol": "http-json-v1",
    "entry": "adapter/macos/cockpit-antigravity-ide-adapter",
    "macosEntry": "adapter/macos/cockpit-antigravity-ide-adapter",
    "windowsEntry": "adapter/windows/cockpit-antigravity-ide-adapter.exe",
    "linuxEntry": "adapter/linux/cockpit-antigravity-ide-adapter",
    "methods": [
      "health.check",
      "accounts.list",
      "accounts.current",
      "accounts.currentId",
      "accounts.saveSnapshot",
      "accounts.addRefreshToken",
      "accounts.setCurrent",
      "accounts.delete",
      "accounts.deleteMany",
      "accounts.reorder",
      "accounts.importOldTools",
      "accounts.importLocal",
      "accounts.syncFromExtension",
      "accounts.importJson",
      "accounts.importFiles",
      "accounts.export",
      "accounts.refresh",
      "accounts.refreshAll",
      "accounts.updateTags",
      "accounts.updateNotes",
      "accounts.groups.load",
      "accounts.groups.save",
      "accounts.syncCurrentFromClient",
      "accounts.refreshCurrent",
      "quota.alertPayload",
      "switch.inject",
      "switch.history.load",
      "switch.history.clear",
      "instances.store.get",
      "instances.store.replace",
      "instance.getDefaults",
      "instance.list",
      "instance.create",
      "instance.update",
      "instance.delete",
      "instance.start",
      "instance.stop",
      "instance.closeAll",
      "instance.openWindow",
      "runtime.detectLaunchPath",
      "runtime.status",
      "runtime.startDefault",
      "runtime.stopDefault",
      "runtime.restartDefault",
      "runtime.focusDefault",
      "runtime.restore",
      "oauth.prepareUrl",
      "oauth.complete",
      "oauth.cancel",
      "oauth.submitCallbackUrl",
      "wakeup.fetchAvailableModels",
      "wakeup.trigger",
      "wakeup.scheduler.syncState",
      "wakeup.scheduler.runEnabledTasks",
      "wakeup.scheduler.confirmTask",
      "wakeup.scheduler.cancelTask",
      "wakeup.scheduler.checkTimeouts",
      "wakeup.runtime.ensureReady",
      "wakeup.crontab.validate",
      "wakeup.sharedHistory.load",
      "wakeup.sharedHistory.add",
      "wakeup.sharedHistory.clear",
      "wakeup.sharedScope.cancel",
      "wakeup.sharedScope.release",
      "wakeup.setOfficialLsVersionMode",
      "wakeup.verification.loadState",
      "wakeup.verification.loadHistory",
      "wakeup.verification.deleteHistory",
      "wakeup.verification.runBatch"
    ]
  },
  "ui": {
    "protocol": "react-remote-esm-v1",
    "entry": "ui/remoteEntry.js",
    "style": "ui/style.css",
    "exports": [
      "mount",
      "unmount"
    ]
  },
  "capabilities": [
    "accounts",
    "oauth",
    "switch",
    "quota",
    "runtime",
    "instances",
    "wakeup",
    "verification"
  ],
  "changelog": [
    {
      "version": "1.0.1",
      "date": "2026-07-02",
      "notes": [
        "Moved platform-specific settings to each platform settings popover, with General settings opening the matching platform settings entry.",
        "Changed account authorization keep-alive to renew due tokens without running default full account or quota scans.",
        "Changed platform package replacement to uninstall the old package before installing the downloaded package."
      ],
      "locales": {
        "zh-CN": {
          "notes": [
            "各平台专属设置迁移到对应平台设置弹框，通用设置只保留跳转入口。",
            "账号授权保活改为只续期到期 token，不再默认全量扫描账号或配额。",
            "平台包替换改为先卸载旧包，再安装已下载的新包。"
          ]
        },
        "zh-TW": {
          "notes": [
            "各平台專屬設定遷移到對應平台設定彈框，通用設定只保留跳轉入口。",
            "帳號授權保活改為只續期到期 token，不再預設全量掃描帳號或配額。",
            "平台包替換改為先解除安裝舊包，再安裝已下載的新包。"
          ]
        }
      }
    },
    {
      "version": "1.0.0",
      "date": "2026-07-01",
      "notes": [
        "Platform has been split into an independent package and now runs independently from the host application."
      ],
      "locales": {
        "zh-CN": {
          "notes": [
            "平台拆成独立的包独立运行。"
          ]
        },
        "zh-TW": {
          "notes": [
            "平台拆成獨立的包並獨立運行。"
          ]
        }
      }
    }
  ],
  "contributions": {
    "platforms": [
      {
        "id": "antigravity_ide",
        "label": "Antigravity IDE",
        "labelKey": "nav.overview",
        "iconKey": "antigravity_ide",
        "page": "overview"
      }
    ],
    "dataPaths": [
      "accounts.json",
      "accounts",
      "groups.json",
      "display_groups.json",
      "instances.json",
      "wakeup_history.json",
      "wakeup_verification_state.json",
      "wakeup_verification_history.json"
    ],
    "localStorageKeys": [
      "agtools.antigravity.runtime_target.v1",
      "agtools.wakeup.enabled",
      "agtools.wakeup.tasks",
      "agtools.wakeup.schedule",
      "agtools.wakeup.official_ls_version_mode",
      "agtools.accountsOverview.antigravity.*"
    ],
    "nativeBoundaries": []
  }
}
