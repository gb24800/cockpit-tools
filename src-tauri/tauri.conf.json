{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeBuddy CN 管家",
  "version": "1.3.13",
  "identifier": "com.codebuddycn.manager",
  "build": {
    "beforeDevCommand": "node scripts/prepare-tauri.cjs && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/prepare-tauri.cjs && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CodeBuddy CN 管家",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false,
        "resizable": true
      },
      {
        "label": "floating-card",
        "title": "CodeBuddy CN 管家",
        "create": false,
        "width": 250,
        "height": 290,
        "minWidth": 250,
        "minHeight": 290,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "externalBin": [],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/48x48.png",
      "icons/32x32.png",
      "icons/16x16.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../src/assets/icons/codebuddy.png": "native-menu-icons/codebuddy.png"
    },
    "macOS": {
      "bundleName": "CodeBuddy CN 管家",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "codebuddycn-manager"
        ]
      }
    }
  }
}
